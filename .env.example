# --- LLM adapter (mock-first) ---
# Leave OPENAI_API_KEY empty to run fully offline with deterministic mocks.
# Real OpenAI activates only if OPENAI_API_KEY is set AND LLM_MODE=openai.
OPENAI_API_KEY=
LLM_MODE=openai
OPENAI_MODEL=gpt-5.4-mini
OPENAI_AGENT_MODEL=gpt-5.4
# Hard timeout (s) for the single hot-path extraction call; breach -> fallback.
LLM_TIMEOUT_S=8

# --- Data / config locations (optional; default to repo-root/data and /config) ---
# DATA_DIR=
# CONFIG_DIR=
# LEADS_MOCK_PATH=
# LEADS_HISTORY_PATH=
# MOCK_EXTRACTIONS_PATH=

# Scoring weights and category thresholds are NOT env knobs: they are JSON
# artifacts under config/ (score_weights_naive.json, category_thresholds.json),
# read by src/scoring/weights.py. A learned config/score_weights.json, if present,
# takes precedence over the naive fallback (see docs/calibration.md).

# Deduplication window (days) for "already seen" lead detection.
DEDUP_WINDOW_DAYS=30

# --- Agent guardrails (§7.4) ---
AGENT_MAX_TURNS=14
AGENT_MAX_MESSAGES=10

APP_PASSWORD=
